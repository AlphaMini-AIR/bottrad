# ============================================================
# 1. MONGO DATABASE - GIỮ NGUYÊN 3 LUỒNG
# ------------------------------------------------------------
# TIER1: dành cho coin tầng 1, không dùng trong luồng scout hiện tại
# TIER2: dành cho coin tầng 2, không dùng trong luồng scout hiện tại
# SCOUT: luồng bot scout hiện tại đang dùng để lưu lệnh paper/live,
#        dữ liệu tự học, trạng thái trade, lịch sử AI.
# ============================================================

# Dành cho 8-12 Coin Tầng 1 (Đánh Live/Paper, lợi nhuận tốt nhất)
MONGO_URI_TIER1=mongodb+srv://assistantsupdev_db_user:rCp0BrUushhwIKR8@binance.bjmukc0.mongodb.net/Binance?appName=Binance

# Dành cho 8-12 Coin Tầng 2 (Học tập, Paper, cạnh tranh)
MONGO_URI_TIER2=mongodb+srv://assistantsupdev_db_user:9WkC4nPZ09NsxOJK@t2.afszz56.mongodb.net/Binance?appName=T2

# Dành cho Coin Tầng 3 / Scout.
# LUỒNG HIỆN TẠI CHỈ DÙNG BIẾN NÀY.
MONGO_URI_SCOUT=mongodb+srv://assistantsupdev_db_user:yuSXb8Q5QFumHL2i@t3.adzm55j.mongodb.net/Binance?appName=T3


# ============================================================
# 2. MODE CHẠY BOT
# ------------------------------------------------------------
# PAPER = dùng thị trường thật từ Binance WebSocket,
#         nhưng lệnh được mô phỏng bằng PaperExchange_V19.
#
# LIVE_DRY_RUN = dùng API Binance thật để validate rule/account,
#                nhưng KHÔNG gửi lệnh thật.
#
# LIVE = gửi lệnh thật. Chưa bật giai đoạn này.
# ============================================================

EXCHANGE_MODE=PAPER
LIVE_DRY_RUN=true


# ============================================================
# 3. REDIS
# ------------------------------------------------------------
# Redis dùng cho:
# - market:features:*
# - dashboard:predictions
# - dashboard:logs
# - system:commands
# - paper wallet
# - feature archive để train ONNX mỗi đêm
# ============================================================

REDIS_URL=redis://127.0.0.1:6379


# ============================================================
# 4. PAPER WALLET - MÔ PHỎNG VÍ 200 USDT
# ------------------------------------------------------------
# PAPER_INITIAL_CAPITAL: số dư ban đầu.
# PAPER_FIXED_MARGIN: mỗi lệnh dùng bao nhiêu USDT margin.
# PAPER_SLIPPAGE_BPS: mô phỏng trượt giá. 2 bps = 0.02%.
# PAPER_MAX_ACCEPTABLE_SPREAD: nếu spread quá rộng thì từ chối vào lệnh.
# ============================================================

PAPER_INITIAL_CAPITAL=200
PAPER_FIXED_MARGIN=2
PAPER_SLIPPAGE_BPS=2
PAPER_MAX_ACCEPTABLE_SPREAD=0.003
PAPER_WALLET_REDIS_KEY=paper:wallet:balance:v19


# ============================================================
# 5. LIVE CONFIG - ĐỂ SẴN NHƯNG CHƯA DÙNG LỆNH THẬT
# ------------------------------------------------------------
# Các biến này chưa gửi lệnh thật khi EXCHANGE_MODE=PAPER.
# Sau này khi chuyển LIVE_DRY_RUN hoặc LIVE sẽ dùng.
# ============================================================

LIVE_FIXED_MARGIN=2
LIVE_MARGIN_TYPE=ISOLATED
LIVE_POSITION_MODE=ONE_WAY
LIVE_FEE_TAKER=0.0004
LIVE_ORDER_FILL_TIMEOUT_MS=15000
LIVE_MAX_RETRIES=2
LIVE_CLIENT_ID_PREFIX=scout


# ============================================================
# 6. BINANCE API KEY - CHƯA BẮT BUỘC Ở PAPER
# ------------------------------------------------------------
# PAPER mode không cần API key vì chỉ dùng public market data.
# Chỉ cần thêm khi chuyển sang LIVE_DRY_RUN hoặc LIVE.
#
# Khi thêm API key, nên dùng key chỉ bật Futures,
# không bật quyền rút tiền.
# ============================================================

# BINANCE_API_KEY=
# BINANCE_API_SECRET=


# ============================================================
# 7. FEATURE RECORDER - LƯU DỮ LIỆU ĐỂ BOT TỰ HỌC MỖI ĐÊM
# ------------------------------------------------------------
# FeatureRecorder nghe market:features:* và lưu vào Redis Stream.
# NightlyTrainingDatasetBuilder sẽ lấy:
# openTs - 60s → closeTs + 60s
# để train lại ONNX.
# ============================================================

FEATURE_ARCHIVE_PREFIX=features:archive
FEATURE_ARCHIVE_SAMPLE_INTERVAL_MS=1000
FEATURE_ARCHIVE_TTL_SEC=259200
FEATURE_ARCHIVE_MAXLEN=300000
FEATURE_ARCHIVE_STORE_FULL=false


# ============================================================
# 8. NIGHTLY TRAINING DATASET
# ------------------------------------------------------------
# Job này không chạy 24/7 bằng PM2.
# Nên chạy bằng cron mỗi đêm.
# ============================================================

TRAINING_DATASET_OUTPUT_DIR=./data/training/nightly
TRAINING_PRE_ENTRY_MS=60000
TRAINING_POST_EXIT_MS=60000
TRAINING_LOOKBACK_HOURS=36
TRAINING_ONLY_UNTRAINED=true
TRAINING_MAX_TRADES_PER_RUN=2000

TRAINING_WIN_ROI_THRESHOLD=0.2
TRAINING_LOSS_ROI_THRESHOLD=-0.2
TRAINING_GOOD_MFE_THRESHOLD=0.5
TRAINING_BAD_MAE_THRESHOLD=-0.5


# ============================================================
# 9. DASHBOARD
# ------------------------------------------------------------
# Giao diện quan sát:
# - watchlist coin
# - AI long/short
# - chart nến live
# - paper wallet
# - lệnh open/closed
# - system health
# ============================================================

DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3010
DASHBOARD_CANDLE_INTERVAL_SEC=5
DASHBOARD_WATCHLIST_EMIT_MS=1000
DASHBOARD_ACCOUNT_EMIT_MS=2000
DASHBOARD_HEALTH_EMIT_MS=3000
DASHBOARD_TRADE_REFRESH_MS=5000
DASHBOARD_FEATURE_LOST_MS=10000
DASHBOARD_FEATURE_STALE_MS=3000


# ============================================================
# 10. HEALTH CHECK
# ------------------------------------------------------------
# Ở PAPER:
# - kiểm tra Redis/Mongo/ONNX/ExchangeRules/FeatureArchive.
# - không cần test UserDataStream.
#
# Khi chuyển LIVE_DRY_RUN:
# - đổi HEALTH_CHECK_USER_STREAM=true
# - thêm BINANCE_API_KEY/BINANCE_API_SECRET
# ============================================================

HEALTH_CHECK_FEATURE_ARCHIVE=true
HEALTH_CHECK_SAMPLE_SYMBOL=BTCUSDT
HEALTH_MIN_ARCHIVE_ENTRIES=1

# chỉ bật khi muốn test private stream thật
HEALTH_CHECK_USER_STREAM=false


# ============================================================
# 11. MODEL / BOT ID
# ------------------------------------------------------------
# MODEL_VERSION dùng để lưu vào ScoutTrade,
# giúp biết lệnh được tạo bởi model nào.
# BOT_ID dùng để phân biệt nhiều bot nếu sau này chạy nhiều instance.
# ============================================================

MODEL_VERSION=Universal_Scout.onnx
BOT_ID=scout-paper-v19


# ============================================================
# 12. BINANCE WEBSOCKET PUBLIC/MARKET
# ------------------------------------------------------------
# FeedHandler V19 dùng public market data thật từ Binance Futures.
# Không cần API key.
# ============================================================

BINANCE_PUBLIC_WS_URL=wss://fstream.binance.com/public/stream
BINANCE_MARKET_WS_URL=wss://fstream.binance.com/market/stream

SUBSCRIPTION_CHANNEL=system:subscriptions
KEEP_ALIVE_CHANNEL=system:keep_alive
FEATURE_CHANNEL_PREFIX=market:features

PUBLISH_FAST_INTERVAL_SEC=0.1
PUBLISH_RADAR_INTERVAL_SEC=0.25
PUBLISH_LOOP_SLEEP_SEC=0.05

MAX_PRICE_AGE_SEC=8
MAX_DEPTH_AGE_SEC=2
MIN_WARMUP_SEC=2
LOCAL_PRICE_WINDOW_SEC=10
USE_LOCAL_PRICE_FEATURES=true
WHALE_TRADE_USDT=5000